---
import '@/styles/globals.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title?: string;
  description?: string;
  lang?: string;
}

const {
  title = 'Boxting Labs — Estudio de software e inteligencia artificial.',
  description = 'Boxting Labs es un estudio boutique de ingeniería de software e IA con base en Lima. Trabajamos con pocas compañías al año en producto, infraestructura y sistemas que importan.',
  lang = 'es',
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const ogImageURL = new URL('/og-image.jpg', Astro.site);

// ES at /, EN at /en/. Compute alternates for hreflang.
const alternateESURL = new URL('/', Astro.site);
const alternateENURL = new URL('/en/', Astro.site);

const englishKeywords =
  'software studio, AI studio, engineering studio Lima, boutique software, product engineering, mobile apps, web platforms, infrastructure, applied AI';
const spanishKeywords =
  'estudio de software, estudio de IA, ingeniería de software Lima, software boutique, ingeniería de producto, aplicaciones móviles, plataformas web, infraestructura, IA aplicada';
---

<!doctype html>
<html lang={lang} class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#FFFDF9" />

    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={description} />
    <meta name="author" content="Boxting Labs" />
    <meta name="keywords" content={lang === 'en' ? englishKeywords : spanishKeywords} />
    <link rel="canonical" href={canonicalURL} />

    <link rel="alternate" hreflang="es-PE" href={alternateESURL} />
    <link rel="alternate" hreflang="en-US" href={alternateENURL} />
    <link rel="alternate" hreflang="x-default" href={alternateESURL} />
    <meta name="geo.region" content="PE-LIM" />
    <meta name="geo.placename" content="Lima, Peru" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageURL} />
    <meta property="og:image:alt" content="Boxting Labs" />
    <meta property="og:image:type" content="image/jpeg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content={lang === 'en' ? 'en_US' : 'es_PE'} />
    <meta property="og:site_name" content="Boxting Labs" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageURL} />
    <meta name="twitter:image:alt" content="Boxting Labs" />
    <meta name="twitter:site" content="@boxtinglabs" />
    <meta name="twitter:creator" content="@boxtinglabs" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&family=DM+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <script type="application/ld+json" is:inline set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'Organization',
      name: 'Boxting Labs',
      description: 'Boutique software and AI engineering studio.',
      url: 'https://www.boxtinglabs.com',
      logo: 'https://www.boxtinglabs.com/og-image.jpg',
      foundingDate: '2026',
      address: { '@type': 'PostalAddress', addressLocality: 'Lima', addressCountry: 'PE' },
      areaServed: [
        { '@type': 'Country', name: 'Peru' },
        { '@type': 'Country', name: 'United States' },
        { '@type': 'Place', name: 'Latin America' },
      ],
      knowsAbout: [
        'Software Engineering',
        'Applied AI',
        'Product Design',
        'Cloud Infrastructure',
        'Mobile Applications',
        'Web Platforms',
      ],
    })} />

    <ClientRouter fallback="animate" />
  </head>
  <body class="min-h-screen bg-paper font-sans text-ink antialiased" transition:animate="fade">
    <slot />

    <script>
      function bindReveals() {
        const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = document.querySelectorAll('.reveal:not(.is-in)');
        if (reduced || !('IntersectionObserver' in window)) {
          els.forEach((el) => el.classList.add('is-in'));
        } else {
          // Stagger reveals within the same group
          document.querySelectorAll('[data-stagger]').forEach((group) => {
            const step = Number(group.getAttribute('data-stagger')) || 60;
            group.querySelectorAll<HTMLElement>('.reveal').forEach((el, i) => {
              if (!el.style.getPropertyValue('--reveal-delay')) {
                el.style.setProperty('--reveal-delay', `${i * step}ms`);
              }
            });
          });
          document.querySelectorAll<HTMLElement>('[data-reveal-delay]').forEach((el) => {
            el.style.setProperty('--reveal-delay', `${el.dataset.revealDelay}ms`);
          });
          const io = new IntersectionObserver(
            (entries) => {
              entries.forEach((e) => {
                if (e.isIntersecting) {
                  (e.target as HTMLElement).classList.add('is-in');
                  io.unobserve(e.target);
                }
              });
            },
            { threshold: 0.12, rootMargin: '0px 0px -60px 0px' }
          );
          els.forEach((el) => io.observe(el));
        }

        // Magnetic CTAs — global
        if (!reduced) {
          document.querySelectorAll<HTMLElement>('[data-magnetic]:not([data-magnetic-bound])').forEach((el) => {
            el.setAttribute('data-magnetic-bound', '1');
            const strength = 0.22;
            const max = 8;
            const onMove = (e: PointerEvent) => {
              const r = el.getBoundingClientRect();
              const dx = (e.clientX - (r.left + r.width / 2)) * strength;
              const dy = (e.clientY - (r.top + r.height / 2)) * strength;
              el.style.setProperty('--mx', `${Math.max(-max, Math.min(max, dx)).toFixed(2)}px`);
              el.style.setProperty('--my', `${Math.max(-max, Math.min(max, dy)).toFixed(2)}px`);
            };
            const reset = () => {
              el.style.setProperty('--mx', '0px');
              el.style.setProperty('--my', '0px');
            };
            el.addEventListener('pointermove', onMove);
            el.addEventListener('pointerleave', reset);
            el.addEventListener('blur', reset);
          });
        }
      }

      document.addEventListener('astro:page-load', bindReveals);
      if (document.readyState !== 'loading') bindReveals();
      else document.addEventListener('DOMContentLoaded', bindReveals);
    </script>
  </body>
</html>
