---
import { Image } from 'astro:assets';
import lockup from '@assets/images/boxting/boxting-lockup-horizontal@2x.png';
import type { ui } from '@/i18n/ui';

interface Props {
  t: typeof ui.es.footer;
  hero: typeof ui.es.hero;
  lang: 'en' | 'es';
}

const { t, hero, lang } = Astro.props;
const year = new Date().getFullYear();
const homeHref = lang === 'es' ? '/' : '/en/';
const siteLabel = lang === 'es' ? 'Sitio' : 'Site';
const studioLabel = lang === 'es' ? 'Estudio' : 'Studio';
---

<footer class="bg-paper border-t hairline border-t mt-9">
  <div class="page py-8 md:py-9" data-stagger="80">
    <!-- Studio facts strip (the meta that used to live in the hero) -->
    <div class="reveal grid grid-cols-2 md:grid-cols-4 gap-5 pb-7 border-b hairline border-b">
      {hero.meta.map((item, i) => (
        <div>
          <p class="eyebrow text-fog">{item.label}</p>
          <p class="mono text-small text-ink mt-1 flex items-center gap-2">
            {i === 3 && (
              <span class="relative inline-flex h-2 w-2 shrink-0">
                <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-mint opacity-60"></span>
                <span class="relative inline-flex h-2 w-2 rounded-full bg-mint"></span>
              </span>
            )}
            <span>{item.value}</span>
          </p>
        </div>
      ))}
    </div>

    <div class="mt-7 grid grid-cols-12 gap-6 items-start">
      <!-- Lockup + tagline -->
      <div class="col-span-12 md:col-span-5 reveal">
        <a href={homeHref} class="inline-block">
          <Image
            src={lockup}
            alt="Boxting Labs"
            widths={[160, 320]}
            sizes="160px"
            class="h-7 md:h-8 w-auto"
            loading="lazy"
          />
        </a>
        <p class="mt-4 text-body text-steel max-w-prose">{t.tagline}</p>
      </div>

      <nav class="col-span-6 md:col-span-3 reveal" aria-label={siteLabel}>
        <p class="eyebrow text-fog">{siteLabel}</p>
        <ul class="mt-3 space-y-2 text-small text-ink">
          <li><a href="#studio" class="hover:text-orange transition-colors duration-quick ease-brand">Studio</a></li>
          <li><a href="#work" class="hover:text-orange transition-colors duration-quick ease-brand">Work</a></li>
          <li><a href="#capabilities" class="hover:text-orange transition-colors duration-quick ease-brand">Practice</a></li>
          <li><a href="#contact" class="hover:text-orange transition-colors duration-quick ease-brand">Contact</a></li>
        </ul>
      </nav>

      <div class="col-span-6 md:col-span-4 reveal">
        <p class="eyebrow text-fog">{studioLabel}</p>
        <ul class="mt-3 space-y-2 text-small">
          <li class="mono text-ink">{t.location}</li>
          <li>
            <a href="mailto:hello@boxtinglabs.com" class="mono text-ink hover:text-orange transition-colors duration-quick ease-brand">
              hello@boxtinglabs.com
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-7 pt-5 border-t hairline border-t flex flex-col md:flex-row items-start md:items-center justify-between gap-3">
      <p class="mono text-caption text-fog">© {year} · {t.rights}</p>
      <div class="flex items-center gap-5">
        <a href="#" class="mono text-caption text-fog hover:text-ink transition-colors duration-quick ease-brand">{t.privacy}</a>
        <a href="#" class="mono text-caption text-fog hover:text-ink transition-colors duration-quick ease-brand">{t.terms}</a>
      </div>
    </div>
  </div>
</footer>
