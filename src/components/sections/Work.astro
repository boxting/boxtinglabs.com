---
import { Image } from 'astro:assets';
import ava1 from '@assets/images/ava/AVA_iPhone_Image_1.png';
import ava2 from '@assets/images/ava/AVA_iPhone_Image_2.png';
import ava3 from '@assets/images/ava/AVA_iPhone_Image_3.png';
import ava4 from '@assets/images/ava/AVA_iPhone_Image_4.png';
import type { ui } from '@/i18n/ui';

interface Props {
  t: typeof ui.es.work;
}

const { t } = Astro.props;
const avaShots = [ava1, ava2, ava3, ava4];

const accentMap = {
  plum: { tint: 'rgba(110,47,102,0.10)', label: 'text-plum' },
  sky: { tint: 'rgba(43,92,230,0.10)', label: 'text-sky' },
  orange: { tint: 'rgba(254,93,28,0.10)', label: 'text-orange' },
} as const;
---

<section id="work" class="py-9 md:py-10">
  <div class="page" data-stagger="80">
    <!-- Section header -->
    <div class="grid grid-cols-12 gap-6 items-end mb-8 md:mb-9">
      <div class="col-span-12 md:col-span-7">
        <p class="eyebrow reveal">{t.eyebrow}</p>
        <h2
          class="reveal mt-4 text-ink"
          style="font-size: clamp(36px, 5vw, 56px); line-height: 1.04; letter-spacing: -0.04em; font-weight: 700;"
        >
          {t.heading}
        </h2>
      </div>
      <div class="col-span-12 md:col-span-5 md:text-right reveal">
        <p class="mono text-caption text-fog">
          <span class="text-orange">●</span> {t.statusBadge}
        </p>
      </div>
    </div>

    <!-- Featured: Ava Cash -->
    <article class="reveal grid grid-cols-12 gap-0 border hairline border rounded-lg bg-cream overflow-hidden lift">
      <!-- Gallery -->
      <div class="col-span-12 lg:col-span-7 relative bg-ink p-6 md:p-7">
        <div class="flex items-center justify-between mb-5">
          <p class="mono text-caption text-orange-300">{t.featured.client}</p>
          <p class="mono text-caption text-cream/40">{t.featured.year}</p>
        </div>

        <div class="flex gap-4 overflow-x-auto pb-2 -mx-2 px-2 snap-x snap-mandatory scrollbar-thin">
          {avaShots.map((shot, i) => (
            <div class="snap-center shrink-0 w-[180px] sm:w-[200px] lg:w-[220px] aspect-[9/19] rounded-md overflow-hidden bg-cream/5 transition-transform duration-base ease-brand hover:-translate-y-1">
              <Image
                src={shot}
                alt={`Ava Cash · vista ${i + 1}`}
                widths={[200, 400]}
                sizes="220px"
                class="w-full h-full object-cover object-top"
                loading={i === 0 ? 'eager' : 'lazy'}
              />
            </div>
          ))}
        </div>
      </div>

      <!-- Copy -->
      <div class="col-span-12 lg:col-span-5 p-6 md:p-7 flex flex-col">
        <h3 class="text-h2 text-ink font-semibold" style="font-size: 36px; letter-spacing: -0.03em;">{t.featured.title}</h3>

        <p class="mt-5 text-body text-steel">{t.featured.outcome}</p>

        <!-- Meta dl -->
        <dl class="mt-auto pt-6 mt-7 grid grid-cols-1 gap-y-3 border-t hairline border-t">
          <div class="flex items-baseline justify-between gap-5">
            <dt class="mono text-caption text-fog shrink-0">{t.metaLabels.industry}</dt>
            <dd class="text-small text-ink text-right">{t.featured.industry}</dd>
          </div>
          <div class="flex items-baseline justify-between gap-5">
            <dt class="mono text-caption text-fog shrink-0">{t.metaLabels.role}</dt>
            <dd class="text-small text-ink text-right">{t.featured.role}</dd>
          </div>
        </dl>
      </div>
    </article>

    <!-- Editorial cards: Jalhuca + New Transport -->
    <ul class="mt-7 grid grid-cols-1 md:grid-cols-2 gap-6">
      {t.projects.map((p) => {
        const accent = accentMap[p.accent as keyof typeof accentMap] ?? accentMap.orange;
        return (
          <li class="reveal">
            <article
              class="group lift glass relative h-full rounded-lg p-6 md:p-7 overflow-hidden hover:shadow-3"
              style="border-radius: 18px;"
            >
              <!-- Iso pattern tinted by accent, sitting *behind* the glass so it shows through -->
              <div
                aria-hidden="true"
                class="iso-pattern absolute inset-0 -z-10 opacity-70 group-hover:opacity-95 transition-opacity duration-base ease-brand"
                style={`background-color: ${accent.tint};`}
              ></div>

              <div class="relative">
                <div class="flex items-baseline justify-between gap-4">
                  <p class={`mono text-caption ${accent.label}`}>{p.client}</p>
                  <span class="mono text-caption text-fog shrink-0">{p.year}</span>
                </div>
                <h3 class="mt-4 text-ink font-semibold" style="font-size: 30px; line-height: 1.1; letter-spacing: -0.028em;">{p.title}</h3>
                <p class="mt-4 text-body text-steel max-w-prose">{p.outcome}</p>

                <dl class="mt-6 pt-5 grid grid-cols-1 gap-2 border-t hairline border-t">
                  <div class="flex items-baseline justify-between gap-5">
                    <dt class="mono text-caption text-fog shrink-0">{t.metaLabels.industry}</dt>
                    <dd class="text-small text-ink text-right">{p.industry}</dd>
                  </div>
                  <div class="flex items-baseline justify-between gap-5">
                    <dt class="mono text-caption text-fog shrink-0">{t.metaLabels.role}</dt>
                    <dd class="text-small text-ink text-right">{p.role}</dd>
                  </div>
                </dl>
              </div>
            </article>
          </li>
        );
      })}
    </ul>
  </div>
</section>
