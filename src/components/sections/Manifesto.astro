---
import type { ui } from '@/i18n/ui';

interface Props {
  t: typeof ui.en.manifesto;
}

const { t } = Astro.props;
---

<section id="studio" class="relative border-t hairline border-t bg-cream py-10 md:py-10 overflow-hidden" data-track-section="manifesto">
  <!-- Faint pattern wash -->
  <div aria-hidden="true" class="iso-pattern pointer-events-none absolute inset-0 opacity-40"></div>
  <div aria-hidden="true" class="pointer-events-none absolute inset-0 bg-gradient-to-b from-cream via-cream/85 to-cream"></div>

  <div class="page relative" data-stagger="100">
    <div class="grid grid-cols-12 gap-6">
      <!-- Left -->
      <div class="col-span-12 lg:col-span-5">
        <p class="eyebrow reveal">{t.eyebrow}</p>
        <h2
          class="reveal mt-4 text-ink"
          style="font-size: clamp(36px, 5vw, 56px); line-height: 1.04; letter-spacing: -0.04em; font-weight: 700;"
        >
          {t.heading}
        </h2>
      </div>

      <!-- Right -->
      <div class="col-span-12 lg:col-span-7 lg:pl-7">
        <p class="reveal text-steel max-w-prose" style="font-size: 19px; line-height: 30px;">
          {t.body}
        </p>
      </div>
    </div>

    <!-- Principles -->
    <ul class="mt-9 grid grid-cols-1 gap-6 md:grid-cols-3 md:gap-7" data-stagger="120">
      {t.principles.map((p) => (
        <li class="reveal group border-t hairline border-t pt-5 transition-colors duration-base ease-brand">
          <div class="flex items-baseline gap-3">
            <span class="mono text-caption text-orange transition-transform duration-base ease-brand group-hover:-translate-y-0.5">{p.n}</span>
            <span aria-hidden="true" class="h-px flex-1 bg-ink/10 transition-colors duration-base ease-brand group-hover:bg-orange/40"></span>
          </div>
          <h3 class="mt-4 text-h3 text-ink font-semibold">{p.title}</h3>
          <p class="mt-2 text-body text-steel">{p.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>
