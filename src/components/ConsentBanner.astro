---
interface Props {
  lang?: 'en' | 'es';
}

const { lang = 'es' } = Astro.props;

const copy = {
  es: {
    body: 'Usamos analítica anónima para entender cómo se navega el sitio. Sin cookies de seguimiento entre dominios.',
    accept: 'Aceptar',
    decline: 'Rechazar',
    aria: 'Banner de consentimiento de analítica',
  },
  en: {
    body: 'We use anonymous analytics to understand how the site is browsed. No cross-site tracking cookies.',
    accept: 'Accept',
    decline: 'Decline',
    aria: 'Analytics consent banner',
  },
}[lang];
---

<div
  id="consent-banner"
  class="consent-banner"
  role="dialog"
  aria-label={copy.aria}
  aria-live="polite"
  hidden
>
  <div class="consent-inner glass-strong">
    <p class="consent-body">{copy.body}</p>
    <div class="consent-actions">
      <button type="button" class="consent-btn consent-btn-ghost" data-consent="deny">
        {copy.decline}
      </button>
      <button type="button" class="consent-btn consent-btn-solid" data-consent="grant">
        {copy.accept}
      </button>
    </div>
  </div>
</div>

<style>
  .consent-banner {
    position: fixed;
    left: 50%;
    bottom: clamp(14px, 3vh, 28px);
    transform: translateX(-50%) translateY(8px);
    z-index: 60;
    width: min(640px, calc(100vw - 32px));
    opacity: 0;
    transition:
      opacity 320ms cubic-bezier(0.16, 1, 0.3, 1),
      transform 320ms cubic-bezier(0.16, 1, 0.3, 1);
    pointer-events: none;
  }
  .consent-banner.is-visible {
    opacity: 1;
    transform: translateX(-50%) translateY(0);
    pointer-events: auto;
  }

  .consent-inner {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 16px 14px 20px;
    border-radius: 18px;
  }

  .consent-body {
    flex: 1;
    margin: 0;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    line-height: 1.45;
    color: rgba(15, 27, 45, 0.78);
    letter-spacing: -0.005em;
  }

  .consent-actions {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    flex-shrink: 0;
  }

  .consent-btn {
    appearance: none;
    border: none;
    cursor: pointer;
    font-family: 'DM Sans', system-ui, sans-serif;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: -0.005em;
    padding: 9px 14px;
    border-radius: 999px;
    transition: background 0.18s, color 0.18s, transform 0.12s;
    white-space: nowrap;
  }
  .consent-btn-ghost {
    background: transparent;
    color: rgba(15, 27, 45, 0.62);
  }
  .consent-btn-ghost:hover {
    background: rgba(15, 27, 45, 0.06);
    color: #0f1b2d;
  }
  .consent-btn-solid {
    background: #0f1b2d;
    color: #fffdf9;
  }
  .consent-btn-solid:hover {
    background: #fe5d1c;
  }
  .consent-btn:active {
    transform: translateY(1px);
  }

  @media (max-width: 520px) {
    .consent-inner {
      flex-direction: column;
      align-items: stretch;
      padding: 14px;
    }
    .consent-actions {
      justify-content: flex-end;
    }
  }
</style>
